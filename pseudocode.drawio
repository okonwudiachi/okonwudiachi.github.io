          <mxGeometry height="60" width="610" x="120" y="20" as="geometry" />
        </mxCell>
        <mxCell id="block_1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#f8f9fa;align=left;spacingLeft=10;spacingTop=8;fontSize=14;" value="START&#xa;Open step page&#xa;Load shared script and saved session data" vertex="1">
