        </mxCell>
        <mxCell id="block_2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#fff2cc;align=left;spacingLeft=10;spacingTop=8;fontSize=14;" value="INITIALIZE PAGE&#xa;- Populate state list&#xa;- Restore saved answers into fields&#xa;- Attach input, blur, and change listeners&#xa;- Activate date helpers, slider display, password checks, and review button behavior" vertex="1">
          <mxGeometry height="130" width="610" x="120" y="210" as="geometry" />
